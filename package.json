{
  "name": "expenses-tracker-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @expenses/web run dev",
    "dev:mobile": "npm --workspace @expenses/mobile run start",
    "build:web": "npm --workspace @expenses/web run build",
    "lint:web": "npm --workspace @expenses/web run lint",
    "dev:api": "npm --workspace @expenses/api run dev",
    "dev:collector": "npm --workspace @expenses/collector run dev"
  }
}
